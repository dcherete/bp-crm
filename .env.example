# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── SECRETS (gere valores aleatórios para produção) ──────────────────────────
JWT_SECRET=troque-por-valor-aleatorio-seguro
SUBSCRIBER_WIDGET_JWT_EXPIRATION_TIME=15d
STORE_ENCRYPTION_KEY=troque-por-32-chars-aleatorios
NOVU_SECRET_KEY=troque-por-valor-aleatorio-seguro

# ─── HOST ─────────────────────────────────────────────────────────────────────
# URL pública da API (use ngrok/cloudflare tunnel em dev, domínio real em prod)
HOST_NAME=https://seu-dominio.com

# ─── AMBIENTE ─────────────────────────────────────────────────────────────────
NODE_ENV=local

# ─── MONGODB ──────────────────────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=troque-por-senha-segura
MONGO_URL=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongodb:27017/novu-db?authSource=admin
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=5
MONGO_AUTO_CREATE_INDEXES=true

# ─── REDIS ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_SERVICE_HOST=
REDIS_CACHE_SERVICE_PORT=6379
DOCKER_REDIS_SERVICE_PORT=6379

# ─── AWS (S3 / SES) ───────────────────────────────────────────────────────────
S3_LOCAL_STACK=http://localhost:4566
S3_BUCKET_NAME=novu-local
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=sua-access-key
AWS_SECRET_ACCESS_KEY=sua-secret-key

# ─── PORTAS ───────────────────────────────────────────────────────────────────
API_PORT=3000
WS_PORT=3002
WORKER_PORT=3004

# ─── URLS FRONT ───────────────────────────────────────────────────────────────
VITE_API_HOSTNAME=http://localhost:3000
VITE_WEBSOCKET_HOSTNAME=http://localhost:3002
VITE_LEGACY_DASHBOARD_URL=http://localhost:4200
API_ROOT_URL=https://seu-dominio.com
FRONT_BASE_URL=http://localhost:4000
DASHBOARD_URL=http://localhost:4200

# ─── FEATURE FLAGS ────────────────────────────────────────────────────────────
IS_API_IDEMPOTENCY_ENABLED=false
IS_API_RATE_LIMITING_ENABLED=false
IS_NEW_MESSAGES_API_RESPONSE_ENABLED=true
IS_V2_ENABLED=true
IS_WORKFLOW_NODE_PREVIEW_ENABLED=false
IS_ENHANCED_DIGEST_ENABLED=false
IS_EMAIL_INLINE_CSS_DISABLED=false
IS_USE_MERGED_DIGEST_ID_ENABLED=false

# ─── ANALYTICS (opcional) ─────────────────────────────────────────────────────
SENTRY_DSN=

# ─── NEW RELIC (opcional) ─────────────────────────────────────────────────────
NEW_RELIC_ENABLED=false
NEW_RELIC_APP_NAME=bp-crm
NEW_RELIC_LICENSE_KEY=

# ─── QUEUE ────────────────────────────────────────────────────────────────────
BROADCAST_QUEUE_CHUNK_SIZE=100
MULTICAST_QUEUE_CHUNK_SIZE=100
